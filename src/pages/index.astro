  },
  {
    title: "Menu Ditambahkan",
    description: "Ketika Vera Sudah Menambahkan Menu Ke Keranjang",
    image: "/images/vera-3.png",
    alt: "Dashboard Realtime Pesanan"
  },
  {
    title: "Pembayaran QRIS",
    description: "Ketika Pelanggan Menyudahi Transaksi Akan Diarahkan Ke Pembayaran Oleh Vera",
