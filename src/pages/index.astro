    alt: "Dashboard Realtime Pesanan"
  },
  {
    title: "Landing Pages",
    description: "Tempat Awal Masuk Website Vera AI",
    image: "/images/landing-pages.png",
    alt: "Landing Pages"
  },
  {
    title: "Login Pages",
    description: "Halaman Masuk Akun Vera AI",
    image: "/images/auth-1.png",
    alt: "Login"
  },
  {
